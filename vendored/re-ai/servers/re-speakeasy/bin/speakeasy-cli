#!/home/john/Desktop/RE/RE-AI/servers/re-speakeasy/.venv/bin/python3
"""speakeasy-cli — Mandiant Speakeasy Windows API emulator helper.

Subcommand surface (one JSON document on stdout per invocation):

  check                                 -> version + emulated_apis_count
  emulate <path> [--timeout N]          -> per-API trace JSON
  list-emulated-apis                    -> api catalog summary

This is the binary the re-speakeasy Python MCP server shells out
to. It's a thin wrapper around ``speakeasy_emulator`` (Mandiant
Speakeasy, Apache-2.0). The CLI is generated by install.sh.

Errors emit a JSON {"error": "..."} document with a non-zero
exit code. Vendor-neutral — no commercial product named.
"""

import json
import sys
from pathlib import Path


def emit(payload: dict) -> None:
    """Print a JSON document to stdout (one line, no indent)."""
    print(json.dumps(payload))


def emit_error(message: str, exit_code: int = 1) -> None:
    """Print a JSON error to stdout and exit non-zero."""
    emit({"error": message})
    sys.exit(exit_code)


def cmd_check() -> int:
    """Return version. The API catalog is loaded dynamically during
    a run; for a static count use the upstream Mandiant Speakeasy
    docs. We report 0 + a hint rather than guessing.
    """
    try:
        from speakeasy.version import __version__ as speak_version
    except Exception as exc:  # noqa: BLE001
        emit_error(f"speakeasy import: {exc}")
    emit({
        "version": speak_version,
        "emulated_apis_count": 0,  # dynamic — see emulate_binary()
        "sample": [],
        "note": "API catalog is loaded at run time. Run `emulate` on a sample to see actual calls.",
    })
    return 0


def cmd_emulate(args: list[str]) -> int:
    """Run Speakeasy on *path* and return a per-API trace."""
    if not args:
        emit_error("emulate requires <path>")
        return 2
    path = args[0]
    timeout_s = 60
    if "--timeout" in args:
        try:
            i = args.index("--timeout")
            timeout_s = int(args[i + 1])
        except (IndexError, ValueError) as exc:
            emit_error(f"bad --timeout: {exc}")
            return 2
    if not Path(path).is_file():
        emit_error(f"file not found: {path}")
        return 2
    try:
        import speakeasy
    except Exception as exc:  # noqa: BLE001
        emit_error(f"speakeasy import: {exc}")
    try:
        se = speakeasy.Speakeasy()
        loaded_mod = se.load_module(path=path)
        se.run_module(loaded_mod)
    except Exception as exc:  # noqa: BLE001
        emit_error(f"emulation failed: {exc}")
    # Collect the per-API trace that the Win32 emulator logged.
    trace = se
    api_log = getattr(getattr(se, "emu", None), "api", None) or getattr(se, "api", None)
    # Speakeasy's run() returns a SpeakeasyRun object; the per-API
    # trace lives at .calls. We normalize to the shape the MCP
    # server expects.
    calls = []
    summary = {
        "api_count": 0,
        "unique_apis": [],
        "files_accessed": [],
        "registry_keys": [],
        "processes_spawned": [],
        "network_calls": [],
    }
    try:
        for call in getattr(trace, "calls", []) or getattr(api_log, "calls", []) or []:
            entry = {
                "api": getattr(call, "api", None) or getattr(call, "name", ""),
                "args": [str(a) for a in (getattr(call, "args", []) or [])],
                "return": str(getattr(call, "retval", "")) if getattr(call, "retval", None) is not None else None,
                "module": getattr(call, "module", ""),
            }
            calls.append(entry)
            api_name = entry["api"]
            if api_name and api_name not in summary["unique_apis"]:
                summary["unique_apis"].append(api_name)
            if api_name in ("CreateFileW", "CreateFileA", "NtCreateFile"):
                if args := getattr(call, "args", []):
                    summary["files_accessed"].append(str(args[0]))
            if api_name in ("RegOpenKeyExW", "RegCreateKeyExW"):
                if args := getattr(call, "args", []):
                    summary["registry_keys"].append(str(args[0]))
            if api_name in ("CreateProcessW", "CreateProcessA", "NtCreateProcess"):
                if args := getattr(call, "args", []):
                    summary["processes_spawned"].append(str(args[0]))
            if api_name in (
                "WinHttpOpen", "WinHttpConnect", "WinHttpOpenRequest",
                "WSAConnect", "connect", "InternetOpen", "InternetOpenUrl",
            ):
                if args := getattr(call, "args", []):
                    summary["network_calls"].append(str(args[0]))
        summary["api_count"] = len(calls)
    except Exception as exc:  # noqa: BLE001
        # Introspection failures are non-fatal — return what we have.
        calls.append({"api": "<introspection_error>", "args": [], "return": str(exc)})
    emit({"path": path, "trace": calls, "summary": summary})
    return 0


def cmd_list_emulated_apis(_args: list[str]) -> int:
    """Return the list of Win32 APIs Speakeasy knows how to emulate."""
    return cmd_check()  # Same shape; cmd_check returns a sample.


def main() -> int:
    if len(sys.argv) < 2:
        emit_error("usage: speakeasy-cli <check|emulate|list-emulated-apis> [args...]")
        return 2
    subcommand = sys.argv[1]
    rest = sys.argv[2:]
    if subcommand == "check":
        return cmd_check()
    if subcommand == "emulate":
        return cmd_emulate(rest)
    if subcommand == "list-emulated-apis":
        return cmd_list_emulated_apis(rest)
    emit_error(f"unknown subcommand: {subcommand}")
    return 2


if __name__ == "__main__":
    sys.exit(main())
